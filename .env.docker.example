# Postgres configuration
POSTGRES_USER=legalflow_admin
POSTGRES_PASSWORD=change_me_in_local_only
POSTGRES_DB=legalflow_prod

# MinIO configuration
MINIO_ROOT_USER=admin_minio
MINIO_ROOT_PASSWORD=change_me_in_local_only
 
# App configuration 
DATABASE_URL=postgresql://legalflow_admin:change_me_in_local_only@postgres:5432/legalflow_prod?schema=public 
JWT_SECRET=dummy_secret_do_not_use_in_prod
 
FRONTEND_ORIGIN=http://127.0.0.1:8080 
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=admin_minio
MINIO_SECRET_KEY=change_me_in_local_only
MINIO_BUCKET=legalflow-docs
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
MINIO_AUTO_CREATE_BUCKET=true

# Seed configuration
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_in_local_only
 
METRICS_INTERNAL_TOKEN=change_me_for_metrics_token\; Add-Content legalflow-backend\.env.example \
METRICS_INTERNAL_TOKEN=change_me_for_metrics_token
