# PostgreSQL Database URL connection string for Docker Local Infra
DATABASE_URL="postgresql://legalflow_admin:change_me_in_local_only@127.0.0.1:5432/legalflow_prod?schema=public"

JWT_SECRET=legalflow_local_dev_secret_2026_change_later
JWT_EXPIRES_IN=28800
FRONTEND_ORIGIN=http://localhost:5173

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=admin_minio
MINIO_SECRET_KEY=change_me_in_local_only
MINIO_BUCKET=legalflow-docs
MINIO_REGION=us-east-1
MINIO_FORCE_PATH_STYLE=true
MINIO_AUTO_CREATE_BUCKET=true

SEED_ADMIN_EMAIL=admin@legalflow.local
SEED_ADMIN_PASSWORD=change_me_in_local_only
SEED_ADMIN_FULL_NAME=Administrator

SEED_MOCK_DATA=false
SEED_MOCK_USERS=false
SEED_MOCK_CASES=false

# AI Module Configuration (Phase 1)
AI_PROVIDER="gemini"
GEMINI_API_KEY="your_google_gemini_api_key_here"
GEMINI_MODEL="gemini-1.5-pro"
AI_ANONYMIZE_DATA=true
