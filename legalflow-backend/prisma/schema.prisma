// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum CaseStatus {
  NEW
  NEEDS_MORE_INFO
  IN_PROGRESS
  RESPONDED
  CLOSED
}

enum CaseType {
  KN
  TC
  KNG
  PA
  TVPL
  KHAC
}

enum CaseField {
  DAT_DAI
  DAN_SU
  LAO_DONG
  HON_NHAN_GIA_DINH
  DOANH_NGHIEP
  HANH_CHINH
  KHAC
}

enum Neighborhood {
  KP1
  KP2
  KP3
  KP4
  KP5
  KHAC
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedCases LegalCase[] @relation("AssignedCases")
  createdCases  LegalCase[] @relation("CreatedCases")

  caseNotes               CaseNote[]
  caseHistories           CaseHistory[]
  completedChecklistItems CaseChecklistItem[]
  aiAuditLogs             AiAuditLog[]

  assignedProcedureCases           AdministrativeProcedureCase[] @relation("AssignedProcedureCases")
  createdProcedureCases            AdministrativeProcedureCase[] @relation("CreatedProcedureCases")
  completedProcedureChecklistItems ProcedureChecklistItem[]      @relation("CompletedProcedureChecklistItems")
  procedureNotes                   ProcedureNote[]               @relation("ProcedureNotes")
  procedureAuditLogs               ProcedureAuditLog[]           @relation("ProcedureAuditLogs")
  createdProcedureAiAnalyses       ProcedureAiAnalysis[]         @relation("CreatedProcedureAiAnalyses")
  reviewedProcedureAiAnalyses      ProcedureAiAnalysis[]         @relation("ReviewedProcedureAiAnalyses")
  createdLegalDocuments            LegalDocument[]               @relation("LegalDocumentCreatedBy")
  approvedLegalDocuments           LegalDocument[]               @relation("LegalDocumentApprovedBy")
  approvedProcedureTypeVersions    ProcedureTypeVersion[]        @relation("ProcedureTypeVersionApprovedBy")
  approvedAiPromptVersions         AiPromptVersion[]             @relation("AiPromptVersionApprovedBy")
  approvedChecklistVersions        ChecklistVersion[]            @relation("ChecklistVersionApprovedBy")
  reviewedLegalUpdateLogs          LegalUpdateLog[]              @relation("LegalUpdateLogReviewedBy")

  createdFinancialAssessments  FinancialObligationAssessment[] @relation("AssessmentCreator")
  reviewedFinancialAssessments FinancialObligationAssessment[] @relation("AssessmentReviewer")
  approvedFinancialAssessments FinancialObligationAssessment[] @relation("AssessmentApprover")
  verifiedTaxNotices           TaxNoticeRecord[]               @relation("TaxNoticeVerifier")
  verifiedPaymentEvidences     PaymentEvidenceRecord[]         @relation("PaymentVerifier")
  financialAuditLogs           FinancialObligationAuditLog[]   @relation("AuditActor")
}

model LegalCase {
  id           String       @id @default(uuid())
  caseCode     String       @unique
  senderName   String
  contact      String?
  type         CaseType
  field        CaseField
  neighborhood Neighborhood
  summary      String
  request      String
  documents    Json         @default("[]")
  receivedDate DateTime     @default(now())
  deadline     DateTime?
  status       CaseStatus   @default(NEW)

  assignedToId String?
  assignedTo   User?   @relation("AssignedCases", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("CreatedCases", fields: [createdById], references: [id], onDelete: SetNull)

  deletedAt   DateTime?
  deletedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes     CaseNote[]
  histories CaseHistory[]
  checklist CaseChecklistItem[]

  landProfile  LandProfile?
  aiAuditLogs  AiAuditLog[]
  aiSuggestion AiCaseSuggestion?
}

enum LandProcedureType {
  CAP_GIAY_CHUNG_NHAN
  CHUYEN_MUC_DICH_SD
  TRANH_CHAP_DAT_DAI
  GIAO_DAT_CHO_THUE_DAT
  THU_HOI_DAT_BOI_THUONG
  KHAC
}

enum LandType {
  DAT_O_DO_THI
  DAT_O_NONG_THON
  DAT_TRONG_LUA
  DAT_TRONG_CAY_LAU_NAM
  DAT_RUNG_PHONG_HO
  DAT_SAN_XUAT_KINH_DOANH
  KHAC
}

enum PlanningStatus {
  TRONG_QUY_HOACH
  NGOAI_QUY_HOACH
  CAN_XAC_MINH_THEM
}

enum DisputeStatus {
  DANG_TRANH_CHAP
  KHONG_TRANH_CHAP
  CAN_XAC_MINH_THEM
}

enum OriginOfLandStatus {
  NHAN_CHUYEN_NHUONG
  DUOC_THUA_KE
  DUOC_TANG_CHO
  DAT_KHAI_HOANG
  NHA_NUOC_GIAO_DAT
  NHA_NUOC_CHO_THUE_DAT
  KHAC
}

enum DocumentCompleteness {
  DU_HO_SO
  THIEU_HO_SO
}

enum FinancialObligationStatus {
  HOAN_THANH
  CHUA_HOAN_THANH
  MIEN_GIAM
}

enum LandOutcome {
  CHAP_THUAN
  TU_CHOI
  CHUYEN_TRA
}

enum LandReasonCode {
  QUY_HOACH_XUNG_DOT
  TRANH_CHAP_CHUA_GIAI_QUYET
  THIEU_GIAY_TO_PHAP_LY
  CHUA_HOAN_THANH_NGHIA_VU_TAI_CHINH
  HO_SO_KHONG_HOP_LE
  KHAC
}

enum ComplaintType {
  KN
  TC
  PA
}

enum RiskReviewStatus {
  AN_TOAN
  CAN_RA_SOAT
  DA_XAC_MINH_BINH_THUONG
  DA_XU_LY_DIEU_CHINH
}

model LandProfile {
  id     String    @id @default(uuid())
  caseId String    @unique
  case   LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  procedureType             LandProcedureType         @default(KHAC)
  landType                  LandType
  currentLandUseType        LandType
  requestedLandUseType      LandType?
  area                      Float
  neighborhood              Neighborhood
  planningStatus            PlanningStatus            @default(NGOAI_QUY_HOACH)
  disputeStatus             DisputeStatus             @default(KHONG_TRANH_CHAP)
  originOfLandStatus        OriginOfLandStatus        @default(KHAC)
  documentCompleteness      DocumentCompleteness      @default(DU_HO_SO)
  financialObligationStatus FinancialObligationStatus @default(HOAN_THANH)
  outcome                   LandOutcome?
  reasonCode                LandReasonCode?

  complaintFlag Boolean        @default(false)
  complaintType ComplaintType?

  processingDays   Int?
  overdueDays      Int?
  riskReviewStatus RiskReviewStatus @default(AN_TOAN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([procedureType])
  @@index([landType])
  @@index([neighborhood])
  @@index([outcome])
  @@index([reasonCode])
  @@index([complaintFlag])
  @@index([planningStatus])
  @@index([procedureType, outcome])
  @@index([neighborhood, outcome])
  @@index([landType, outcome])
  @@index([complaintFlag, outcome])
}

model CaseSequence {
  year         Int      @id
  lastSequence Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model CaseNote {
  id        String    @id @default(uuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime  @default(now())
}

model CaseHistory {
  id        String    @id @default(uuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   Json      @default("{}")
  createdAt DateTime  @default(now())
}

model CaseChecklistItem {
  id            String    @id @default(uuid())
  caseId        String
  case          LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title         String
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  completedBy   User?     @relation(fields: [completedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  actorEmail   String
  action       String
  targetUserId String?
  targetEmail  String?
  details      Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([action])
  @@index([actorEmail])
  @@index([targetEmail])
  @@index([createdAt])
}

enum AiActionType {
  SUMMARIZE
  CLASSIFY
  CHECKLIST
  DRAFT
}

enum AiLogStatus {
  SUCCESS
  ERROR
}

enum AiFeedbackStatus {
  PENDING
  ACCEPTED
  REJECTED
  MODIFIED
}

model AiAuditLog {
  id     String     @id @default(uuid())
  caseId String?
  case   LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  actionType       AiActionType
  modelName        String
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?

  inputPayload  Json
  outputPayload Json

  status       AiLogStatus
  errorMessage String?

  userFeedback AiFeedbackStatus @default(PENDING)
  appliedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([userId])
  @@index([actionType])
  @@index([status])
  @@index([createdAt])
}

model AiCaseSuggestion {
  id     String    @id @default(uuid())
  caseId String    @unique
  case   LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  suggestedSummary String?
  suggestedType    CaseType?
  suggestedField   CaseField?
  confidenceScore  Float?
  legalRationale   String?

  isApplied       Boolean  @default(false)
  lastGeneratedAt DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isApplied])
}

enum ProcedureField {
  DAT_DAI
  XAY_DUNG
  KHAC
}

enum ProcedureGroup {
  CAP_GCN_LAN_DAU
  CHUYEN_MUC_DICH_SDD
  NGHIA_VU_TAI_CHINH
  CAP_PHEP_XAY_DUNG
  KHAC
}

enum ProcedureStatus {
  SUBMITTED
  IN_REVIEW
  SUPPLEMENT_REQUIRED
  PENDING_APPROVAL
  COMPLETED
  REJECTED
}

enum ProcedureDocReviewStatus {
  VALID
  MISSING
  NEEDS_VERIFICATION
}

enum ProcedurePriority {
  HIGH
  MEDIUM
  LOW
}

enum ProcedureNoteType {
  GENERAL
  OFFICER_REVIEW
  FIELD_INSPECTION
}

model ProcedureType {
  id                 String         @id @default(uuid())
  code               String         @unique
  name               String
  field              ProcedureField
  group              ProcedureGroup
  description        String?
  legalBasis         String?
  requiredDocuments  Json           @default("[]")
  processingTimeDays Int            @default(15)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  procedureCases AdministrativeProcedureCase[]
  versions       ProcedureTypeVersion[]

  @@index([field])
  @@index([group])
  @@index([isActive])
}

model AdministrativeProcedureCase {
  id                  String          @id @default(uuid())
  caseCode            String          @unique
  procedureTypeId     String
  procedureType       ProcedureType   @relation(fields: [procedureTypeId], references: [id], onDelete: Restrict)
  field               ProcedureField
  applicantName       String
  applicantAddress    String?
  applicantPhone      String?
  landParcelSummary   Json?
  constructionSummary Json?
  status              ProcedureStatus @default(SUBMITTED)
  receivedAt          DateTime        @default(now())
  dueDate             DateTime?
  assignedToId        String?
  assignedTo          User?           @relation("AssignedProcedureCases", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById         String?
  createdBy           User?           @relation("CreatedProcedureCases", fields: [createdById], references: [id], onDelete: SetNull)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  documents                     ProcedureDocument[]
  checklistItems                ProcedureChecklistItem[]
  procedureNotes                ProcedureNote[]
  auditLogs                     ProcedureAuditLog[]
  aiAnalyses                    ProcedureAiAnalysis[]
  financialObligationAssessment FinancialObligationAssessment? @relation("ProcedureCaseFinancialAssessment")

  @@index([procedureTypeId])
  @@index([field])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model ProcedureDocument {
  id              String                      @id @default(uuid())
  procedureCaseId String
  procedureCase   AdministrativeProcedureCase @relation(fields: [procedureCaseId], references: [id], onDelete: Cascade)
  documentType    String
  title           String
  fileUrl         String?
  objectKey       String?
  extractedText   String?
  reviewStatus    ProcedureDocReviewStatus    @default(NEEDS_VERIFICATION)
  officerNote     String?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([procedureCaseId])
}

model ProcedureChecklistItem {
  id              String                      @id @default(uuid())
  procedureCaseId String
  procedureCase   AdministrativeProcedureCase @relation(fields: [procedureCaseId], references: [id], onDelete: Cascade)
  checklistGroup  String
  title           String
  description     String?
  priority        ProcedurePriority           @default(MEDIUM)
  isCompleted     Boolean                     @default(false)
  completedById   String?
  completedBy     User?                       @relation("CompletedProcedureChecklistItems", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt     DateTime?
  isAiSuggested   Boolean                     @default(false)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([procedureCaseId])
  @@index([isCompleted])
}

model ProcedureNote {
  id              String                      @id @default(uuid())
  procedureCaseId String
  procedureCase   AdministrativeProcedureCase @relation(fields: [procedureCaseId], references: [id], onDelete: Cascade)
  userId          String
  user            User                        @relation("ProcedureNotes", fields: [userId], references: [id], onDelete: Cascade)
  content         String
  noteType        ProcedureNoteType           @default(GENERAL)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([procedureCaseId])
  @@index([userId])
}

model ProcedureAuditLog {
  id              String                       @id @default(uuid())
  procedureCaseId String?
  procedureCase   AdministrativeProcedureCase? @relation(fields: [procedureCaseId], references: [id], onDelete: SetNull)
  userId          String
  user            User                         @relation("ProcedureAuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  actionType      String
  entityType      String
  entityId        String?
  inputPayload    Json                         @default("{}")
  outputPayload   Json                         @default("{}")
  createdAt       DateTime                     @default(now())

  @@index([procedureCaseId])
  @@index([userId])
  @@index([actionType])
}

enum ProcedureAiAnalysisType {
  LAND_FIRST_CERTIFICATE_REVIEW
  LAND_USE_PURPOSE_CHANGE_REVIEW
  FINANCIAL_OBLIGATION_REVIEW
  CONSTRUCTION_PERMIT_REVIEW
}

enum ProcedureAiAnalysisStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ProcedureAiAnalysis {
  id              String                            @id @default(uuid())
  procedureCaseId String
  procedureCase   AdministrativeProcedureCase       @relation(fields: [procedureCaseId], references: [id], onDelete: Cascade)
  analysisType    ProcedureAiAnalysisType
  inputSnapshot   Json                              @default("{}")
  outputPayload   Json                              @default("{}")
  disclaimer      String                            @default("BẢN GỢI Ý AI – CÁN BỘ PHẢI KIỂM TRA")
  confidenceLevel String                            @default("MEDIUM")
  status          ProcedureAiAnalysisStatus         @default(PENDING)
  createdById     String
  createdBy       User                              @relation("CreatedProcedureAiAnalyses", fields: [createdById], references: [id], onDelete: Cascade)
  reviewedById    String?
  reviewedBy      User?                             @relation("ReviewedProcedureAiAnalyses", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt
  legalSnapshot   ProcedureAiAnalysisLegalSnapshot?

  @@index([procedureCaseId])
  @@index([analysisType])
  @@index([status])
  @@index([createdById])
}

enum LegalDocumentType {
  LAW
  DECREE
  CIRCULAR
  DECISION
  INTERNAL_PROCESS
  LAND_PRICE_TABLE
  OTHER
}

enum LegalDocumentStatus {
  DRAFT
  ACTIVE
  AMENDED
  EXPIRED
  REPLACED
  ARCHIVED
}

enum LegalDocumentRelationType {
  AMENDS
  REPLACES
  GUIDES
  ANNULS
  REFERENCES
  IMPLEMENTS
}

enum VersionStatus {
  DRAFT
  REVIEWING
  APPROVED
  ACTIVE
  ARCHIVED
  EXPIRED
  REPLACED
}

enum LegalUpdateReviewStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  APPLIED
}

model LegalDocument {
  id               String              @id @default(cuid())
  documentCode     String
  documentTitle    String
  documentType     LegalDocumentType
  issuingAuthority String?
  issuedDate       DateTime?
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  status           LegalDocumentStatus @default(DRAFT)
  sourceUrl        String?
  fileObjectKey    String?
  summary          String?
  notes            String?
  createdById      String?
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  createdBy         User?                   @relation("LegalDocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy        User?                   @relation("LegalDocumentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  outgoingRelations LegalDocumentRelation[] @relation("SourceDocument")
  incomingRelations LegalDocumentRelation[] @relation("TargetDocument")
  updateLogs        LegalUpdateLog[]        @relation("SourceDocumentForUpdateLog")

  @@index([documentCode])
  @@index([documentType])
  @@index([status])
  @@index([effectiveFrom])
  @@index([effectiveTo])
}

model LegalDocumentRelation {
  id                String                    @id @default(cuid())
  documentId        String
  relatedDocumentId String
  relationType      LegalDocumentRelationType
  description       String?
  effectiveFrom     DateTime?
  createdAt         DateTime                  @default(now())

  document        LegalDocument @relation("SourceDocument", fields: [documentId], references: [id], onDelete: Cascade)
  relatedDocument LegalDocument @relation("TargetDocument", fields: [relatedDocumentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([relatedDocumentId])
  @@index([relationType])
}

model ProcedureTypeVersion {
  id                    String        @id @default(cuid())
  procedureTypeId       String
  version               String
  effectiveFrom         DateTime?
  effectiveTo           DateTime?
  status                VersionStatus @default(DRAFT)
  procedureName         String
  procedureCode         String?
  field                 String?
  group                 String?
  requiredDocuments     Json?
  processingTimeDays    Int?
  receivingAgency       String?
  resolvingAgency       String?
  workflowSteps         Json?
  legalBasisDocumentIds Json?
  approvedById          String?
  approvedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  procedureType  ProcedureType                      @relation(fields: [procedureTypeId], references: [id], onDelete: Cascade)
  approvedBy     User?                              @relation("ProcedureTypeVersionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  legalSnapshots ProcedureAiAnalysisLegalSnapshot[]

  @@unique([procedureTypeId, version])
  @@index([procedureTypeId])
  @@index([status])
  @@index([effectiveFrom])
  @@index([effectiveTo])
}

model AiPromptVersion {
  id                String        @id @default(cuid())
  promptKey         String
  version           String
  procedureTypeCode String?
  procedureGroup    String?
  analysisType      String?
  systemPrompt      String
  outputSchema      Json?
  legalDocumentIds  Json?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  status            VersionStatus @default(DRAFT)
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  approvedBy     User?                              @relation("AiPromptVersionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  legalSnapshots ProcedureAiAnalysisLegalSnapshot[]

  @@unique([promptKey, version])
  @@index([promptKey])
  @@index([analysisType])
  @@index([status])
}

model ChecklistVersion {
  id                String        @id @default(cuid())
  checklistKey      String
  version           String
  procedureTypeCode String?
  procedureGroup    String?
  checklistItems    Json
  legalDocumentIds  Json?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  status            VersionStatus @default(DRAFT)
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  approvedBy     User?                              @relation("ChecklistVersionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  legalSnapshots ProcedureAiAnalysisLegalSnapshot[]

  @@unique([checklistKey, version])
  @@index([checklistKey])
  @@index([procedureTypeCode])
  @@index([procedureGroup])
  @@index([status])
}

model LegalUpdateLog {
  id                     String                  @id @default(cuid())
  updateTitle            String
  sourceDocumentId       String?
  affectedDocumentIds    Json?
  affectedProcedureTypes Json?
  affectedPromptKeys     Json?
  affectedChecklistKeys  Json?
  impactSummary          String?
  reviewStatus           LegalUpdateReviewStatus @default(PENDING)
  reviewedById           String?
  reviewedAt             DateTime?
  appliedAt              DateTime?
  notes                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  sourceDocument LegalDocument? @relation("SourceDocumentForUpdateLog", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  reviewedBy     User?          @relation("LegalUpdateLogReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([sourceDocumentId])
  @@index([reviewStatus])
  @@index([createdAt])
}

model ProcedureAiAnalysisLegalSnapshot {
  id                     String   @id @default(cuid())
  procedureAiAnalysisId  String   @unique
  legalDocumentIds       Json?
  promptVersionId        String?
  checklistVersionId     String?
  procedureTypeVersionId String?
  knowledgeBaseVersion   String?
  snapshotJson           Json?
  createdAt              DateTime @default(now())

  procedureAiAnalysis  ProcedureAiAnalysis   @relation(fields: [procedureAiAnalysisId], references: [id], onDelete: Cascade)
  promptVersion        AiPromptVersion?      @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  checklistVersion     ChecklistVersion?     @relation(fields: [checklistVersionId], references: [id], onDelete: SetNull)
  procedureTypeVersion ProcedureTypeVersion? @relation(fields: [procedureTypeVersionId], references: [id], onDelete: SetNull)

  @@index([procedureAiAnalysisId])
  @@index([promptVersionId])
  @@index([checklistVersionId])
  @@index([procedureTypeVersionId])
}

// ============================================================================
// FINANCIAL OBLIGATION SUPPORT MODULE (Phase 12C)
