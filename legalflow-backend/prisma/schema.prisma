// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("VIEWER")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedCases LegalCase[] @relation("AssignedCases")
  createdCases  LegalCase[] @relation("CreatedCases")

  caseNotes               CaseNote[]
  caseHistories           CaseHistory[]
  completedChecklistItems CaseChecklistItem[]
}

model LegalCase {
  id           String    @id @default(uuid())
  caseCode     String    @unique
  senderName   String
  contact      String?
  type         String
  field        String
  neighborhood String
  summary      String
  request      String
  documents    String    @default("[]")
  receivedDate DateTime  @default(now())
  deadline     DateTime?
  status       String    @default("NEW")

  assignedToId String?
  assignedTo   User?     @relation("AssignedCases", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?     @relation("CreatedCases", fields: [createdById], references: [id], onDelete: SetNull)

  deletedAt   DateTime?
  deletedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes     CaseNote[]
  histories CaseHistory[]
  checklist CaseChecklistItem[]
}

model CaseSequence {
  year         Int      @id
  lastSequence Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model CaseNote {
  id        String    @id @default(uuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime  @default(now())
}

model CaseHistory {
  id        String    @id @default(uuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String    @default("{}")
  createdAt DateTime  @default(now())
}

model CaseChecklistItem {
  id            String    @id @default(uuid())
  caseId        String
  case          LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title         String
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  completedBy   User?     @relation(fields: [completedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
}
