// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum CaseStatus {
  NEW
  NEEDS_MORE_INFO
  IN_PROGRESS
  RESPONDED
  CLOSED
}

enum CaseType {
  KN
  TC
  KNG
  PA
  TVPL
  KHAC
}

enum CaseField {
  DAT_DAI
  DAN_SU
  LAO_DONG
  HON_NHAN_GIA_DINH
  DOANH_NGHIEP
  HANH_CHINH
  KHAC
}

enum Neighborhood {
  KP1
  KP2
  KP3
  KP4
  KP5
  KHAC
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedCases LegalCase[] @relation("AssignedCases")
  createdCases  LegalCase[] @relation("CreatedCases")

  caseNotes               CaseNote[]
  caseHistories           CaseHistory[]
  completedChecklistItems CaseChecklistItem[]
  aiAuditLogs             AiAuditLog[]
}

model LegalCase {
  id           String       @id @default(uuid())
  caseCode     String       @unique
  senderName   String
  contact      String?
  type         CaseType
  field        CaseField
  neighborhood Neighborhood
  summary      String
  request      String
  documents    Json         @default("[]")
  receivedDate DateTime     @default(now())
  deadline     DateTime?
  status       CaseStatus   @default(NEW)

  assignedToId String?
  assignedTo   User?        @relation("AssignedCases", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?        @relation("CreatedCases", fields: [createdById], references: [id], onDelete: SetNull)

  deletedAt   DateTime?
  deletedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes     CaseNote[]
  histories CaseHistory[]
  checklist CaseChecklistItem[]

  landProfile  LandProfile?
  aiAuditLogs  AiAuditLog[]
  aiSuggestion AiCaseSuggestion?
}

enum LandProcedureType {
  CAP_GIAY_CHUNG_NHAN
  CHUYEN_MUC_DICH_SD
  TRANH_CHAP_DAT_DAI
  GIAO_DAT_CHO_THUE_DAT
  THU_HOI_DAT_BOI_THUONG
  KHAC
}

enum LandType {
  DAT_O_DO_THI
  DAT_O_NONG_THON
  DAT_TRONG_LUA
  DAT_TRONG_CAY_LAU_NAM
  DAT_RUNG_PHONG_HO
  DAT_SAN_XUAT_KINH_DOANH
  KHAC
}

enum PlanningStatus {
  TRONG_QUY_HOACH
  NGOAI_QUY_HOACH
  CAN_XAC_MINH_THEM
}

enum DisputeStatus {
  DANG_TRANH_CHAP
  KHONG_TRANH_CHAP
  CAN_XAC_MINH_THEM
}

enum OriginOfLandStatus {
  NHAN_CHUYEN_NHUONG
  DUOC_THUA_KE
  DUOC_TANG_CHO
  DAT_KHAI_HOANG
  NHA_NUOC_GIAO_DAT
  NHA_NUOC_CHO_THUE_DAT
  KHAC
}

enum DocumentCompleteness {
  DU_HO_SO
  THIEU_HO_SO
}

enum FinancialObligationStatus {
  HOAN_THANH
  CHUA_HOAN_THANH
  MIEN_GIAM
}

enum LandOutcome {
  CHAP_THUAN
  TU_CHOI
  CHUYEN_TRA
}

enum LandReasonCode {
  QUY_HOACH_XUNG_DOT
  TRANH_CHAP_CHUA_GIAI_QUYET
  THIEU_GIAY_TO_PHAP_LY
  CHUA_HOAN_THANH_NGHIA_VU_TAI_CHINH
  HO_SO_KHONG_HOP_LE
  KHAC
}

enum ComplaintType {
  KN
  TC
  PA
}

enum RiskReviewStatus {
  AN_TOAN
  CAN_RA_SOAT
  DA_XAC_MINH_BINH_THUONG
  DA_XU_LY_DIEU_CHINH
}

model LandProfile {
  id                        String                     @id @default(uuid())
  caseId                    String                     @unique
  case                      LegalCase                  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  procedureType             LandProcedureType          @default(KHAC)
  landType                  LandType
  currentLandUseType        LandType
  requestedLandUseType      LandType?                  
  area                      Float                      
  neighborhood              Neighborhood               
  planningStatus            PlanningStatus             @default(NGOAI_QUY_HOACH)
  disputeStatus             DisputeStatus              @default(KHONG_TRANH_CHAP)
  originOfLandStatus        OriginOfLandStatus         @default(KHAC)
  documentCompleteness      DocumentCompleteness       @default(DU_HO_SO)
  financialObligationStatus FinancialObligationStatus  @default(HOAN_THANH)
  outcome                   LandOutcome?               
  reasonCode                LandReasonCode?            
  
  complaintFlag             Boolean                    @default(false)
  complaintType             ComplaintType?             
  
  processingDays            Int?                       
  overdueDays               Int?                       
  riskReviewStatus          RiskReviewStatus           @default(AN_TOAN)
  
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([procedureType])
  @@index([landType])
  @@index([neighborhood])
  @@index([outcome])
  @@index([reasonCode])
  @@index([complaintFlag])
  @@index([planningStatus])

  @@index([procedureType, outcome])
  @@index([neighborhood, outcome])
  @@index([landType, outcome])
  @@index([complaintFlag, outcome])
}

model CaseSequence {
  year         Int      @id
  lastSequence Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model CaseNote {
  id        String    @id @default(uuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime  @default(now())
}

model CaseHistory {
  id        String    @id @default(uuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   Json      @default("{}")
  createdAt DateTime  @default(now())
}

model CaseChecklistItem {
  id            String    @id @default(uuid())
  caseId        String
  case          LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title         String
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  completedBy   User?     @relation(fields: [completedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  actorEmail   String
  action       String
  targetUserId String?
  targetEmail  String?
  details      Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([action])
  @@index([actorEmail])
  @@index([targetEmail])
  @@index([createdAt])
}

enum AiActionType {
  SUMMARIZE
  CLASSIFY
  CHECKLIST
  DRAFT
}

enum AiLogStatus {
  SUCCESS
  ERROR
}

enum AiFeedbackStatus {
  PENDING
  ACCEPTED
  REJECTED
  MODIFIED
}

model AiAuditLog {
  id               String           @id @default(uuid())
  caseId           String?
  case             LegalCase?       @relation(fields: [caseId], references: [id], onDelete: SetNull)
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  actionType       AiActionType
  modelName        String
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?
  
  inputPayload     Json
  outputPayload    Json
  
  status           AiLogStatus
  errorMessage     String?
  
  userFeedback     AiFeedbackStatus @default(PENDING)
  appliedAt        DateTime?
  
  createdAt        DateTime         @default(now())

  @@index([caseId])
  @@index([userId])
  @@index([actionType])
  @@index([status])
  @@index([createdAt])
}

model AiCaseSuggestion {
  id               String     @id @default(uuid())
  caseId           String     @unique
  case             LegalCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  suggestedSummary String?
  suggestedType    CaseType?
  suggestedField   CaseField?
  confidenceScore  Float?
  legalRationale   String?
  
  isApplied        Boolean    @default(false)
  lastGeneratedAt  DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([isApplied])
}
